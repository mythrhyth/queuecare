# Port the server runs on (default: 5000)
PORT=5000

# Database connection URL. 
# For development (SQLite): "file:./dev.db"
# For production (PostgreSQL/Neon): "postgresql://username:password@hostname:5432/dbname?sslmode=require"
DATABASE_URL="file:./dev.db"

# JWT Secret for encrypting receptionist and admin credentials session tokens
JWT_SECRET=your_jwt_secret_key_here

# Frontend Client URL origin to restrict CORS and prevent cross-origin errors
# In production, replace with your deployed client URL (e.g. https://queuecare.netlify.app)
FRONTEND_URL=http://localhost:5173
